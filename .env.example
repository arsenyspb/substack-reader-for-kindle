# Gmail Configuration (Burner or Personal with Label)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-specific-password

# Ingestion restricted to a specific label for safety/batching
IMAP_FOLDER=Substack-Kindle
IMAP_PROCESSING_FOLDER=Substack-Kindle-Processed

# Kindle Delivery
KINDLE_EMAIL=your-kindle-email@kindle.com

# Google Sheets Configuration (via Apps Script Web App)
WEB_APP_URL=https://script.google.com/macros/s/.../exec
WEB_APP_SECRET=your-pre-shared-secret-key

# Filtering Configuration (Comma-separated list of allowed senders)
WHITELISTED_SENDERS=user1@example.com,user2@example.com
